# Copy to .env and fill in real values for production.

# SQLite by default; switch to Postgres in prod, e.g.
#   postgresql+psycopg://user:password@localhost:5432/aqi
DATABASE_URL=sqlite:///./aqi_india.db

# WAQI token. "demo" works for low-volume testing on most Indian cities.
# Request a real key at https://aqicn.org/data-platform/token/
WAQI_TOKEN=demo

# Comma-separated origins allowed by CORS. Defaults to Vite's dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
